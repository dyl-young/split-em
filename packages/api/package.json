{
  "name": "@no-stack/api",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf .turbo node_modules",
    "dev": "tsc --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "prettier": "@no-stack/prettier-config",
  "dependencies": {
    "@no-stack/db": "workspace:*",
    "@no-stack/validators": "workspace:*",
    "@supabase/supabase-js": "^2.87.1",
    "@trpc/server": "catalog:",
    "nanoid": "^5.0.9",
    "pg": "^8.12.0",
    "postgres": "^3.4.4",
    "superjson": "2.2.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@no-stack/eslint-config": "workspace:*",
    "@no-stack/prettier-config": "workspace:*",
    "@no-stack/tsconfig": "workspace:*",
    "@types/pg": "^8.12.0",
    "eslint": "catalog:",
    "minimatch": "^10.0.1",
    "prettier": "catalog:",
    "typescript": "catalog:"
  }
}
