{
  "name": "@no-stack/db",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf .turbo node_modules",
    "dev": "tsc --watch",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "generate": "pnpm with-env drizzle-kit generate",
    "generate-custom": "pnpm with-env drizzle-kit generate --custom",
    "lint": "eslint",
    "migrate": "pnpm with-env drizzle-kit migrate",
    "migrate:script": "pnpm with-env tsx src/migrate.ts",
    "push": "pnpm with-env drizzle-kit push",
    "studio": "pnpm with-env drizzle-kit studio",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "prettier": "@no-stack/prettier-config",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@t3-oss/env-core": "^0.13.10",
    "@vercel/postgres": "^0.10.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3"
  },
  "devDependencies": {
    "@no-stack/eslint-config": "workspace:*",
    "@no-stack/prettier-config": "workspace:*",
    "@no-stack/tsconfig": "workspace:*",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.5",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}
