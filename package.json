{
  "name": "no-stack",
  "private": true,
  "scripts": {
    "_git:pre-commit": "pnpm exec lint-staged",
    "_git:pre-push": "node scripts/checkTags.js",
    "build": "turbo build",
    "clean": "git clean -xdf node_modules && rm pnpm-lock.yaml",
    "clean:workspaces": "turbo clean",
    "db:generate": "pnpm -F db generate",
    "db:generate-custom": "pnpm -F db generate-custom",
    "db:introspect": "pnpm -F db introspect ",
    "db:migrate-local": "pnpm -F supabase supabase:migrate-local",
    "db:push": "pnpm -F db push",
    "db:studio": "pnpm -F db studio",
    "dev": "turbo dev --parallel --ui=tui",
    "dev:without-expo": "turbo -F=!@no-stack/expo dev --parallel --ui=tui",
    "expo:android": "pnpm --filter expo android",
    "expo:dev": "pnpm --filter expo dev",
    "expo:ios": "pnpm --filter expo ios",
    "expo:prebuild": "pnpm --filter expo expo:prebuild",
    "expo:prebuild:clean": "pnpm --filter expo expo:prebuild:clean",
    "format": "turbo format --continue -- --cache --cache-location node_modules/.cache/.prettiercache",
    "format:fix": "turbo format --continue -- --write --cache --cache-location node_modules/.cache/.prettiercache",
    "postinstall": "pnpm lint:ws",
    "lint": "turbo lint --continue -- --cache --cache-location node_modules/.cache/.eslintcache",
    "lint:fix": "turbo lint --continue -- --fix --cache --cache-location node_modules/.cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest -i react -i react-dom -i @types/react -i @types/react-dom",
    "prepare": "husky",
    "rename-project": "read -p 'Enter new project name: ' NEW_NAME && npx replace 'no-stack' $NEW_NAME . -r --exclude=\"node_modules,.git,dist,.next\" && npx sort-package-json \"**/package.json\"",
    "supabase:clean-db": "pnpm -F supabase clean-db",
    "supabase:deploy": "pnpm -F supabase supabase:deploy",
    "supabase:update-config": "pnpm -F supabase update-config",
    "typecheck": "turbo typecheck"
  },
  "lint-staged": {
    "*.{js, ts, jsx, tsx}": [
      "pnpm format:fix",
      "pnpm lint:fix"
    ]
  },
  "prettier": "@no-stack/prettier-config",
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@no-stack/prettier-config": "workspace:*",
    "@turbo/gen": "^2.9.15",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "catalog:",
    "sort-package-json": "^3.6.1",
    "turbo": "^2.9.15",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "pnpm": {
    "overrides": {
      "cross-spawn@<6.0.6": ">=6.0.6",
      "esbuild": "0.25.5",
      "fast-uri@<3.1.2": ">=3.1.2",
      "flatted@<=3.4.1": ">=3.4.2",
      "form-data": ">=4.0.4",
      "glob@>10.3.7 <=11.0.3": ">=11.1.0",
      "lightningcss": "1.30.1",
      "qs@<6.14.1": ">=6.14.1",
      "undici@<6.24.0": ">=6.24.0",
      "@xmldom/xmldom@<0.9.10": ">=0.9.10"
    }
  }
}
